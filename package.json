{
  "name": "@collegevine/trellis-app-sdk",
  "version": "0.1.0",
  "private": true,
  "description": "Server-side SDK for Trellis Apps to call CollegeVine data sources via the Trellis App API.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./auth/middleware": {
      "types": "./dist/auth/middleware.d.ts",
      "default": "./dist/auth/middleware.js"
    },
    "./auth/rrv7-middleware": {
      "types": "./dist/auth/rrv7-middleware.d.ts",
      "default": "./dist/auth/rrv7-middleware.js"
    },
    "./auth/server": {
      "types": "./dist/auth/server.d.ts",
      "default": "./dist/auth/server.js"
    },
    "./lambda": {
      "types": "./dist/lambda.d.ts",
      "default": "./dist/lambda.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepare": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "next": "^15.0.0",
    "react-router": "^7.0.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    },
    "react-router": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/pg": "^8.20.0",
    "next": "^15.0.0",
    "react-router": "^7.0.0",
    "typescript": "^5.6.0",
    "vitest": "^3.2.6"
  },
  "dependencies": {
    "@aws-sdk/rds-signer": "^3.1063.0",
    "pg": "^8.21.0"
  }
}
